# --- Shopify headless (Storefront API) ---
# Copy this file to ".env.local" (which is git-ignored) and fill in your values.
# In production, set the same variables in your Vercel project settings.
#
# 1. In Shopify admin: Settings → Apps and sales channels → Develop apps
#    → Create an app → Configure Storefront API scopes
#    (enable: read_products, read_product_listings; for cart/checkout later:
#     unauthenticated_read_product_listings, unauthenticated_write_checkouts).
# 2. Install the app, then copy the "Storefront API access token".
#
# Your store's *.myshopify.com domain (NOT the custom domain):
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# The Storefront API access token from your custom app:
SHOPIFY_STOREFRONT_TOKEN=your_storefront_api_token_here


# --- Age verification (18+) ---
# Mode: "yoti" (real Yoti flow), "demo" (simulated, for testing), or "off"
# (fail-closed: checkout blocked). Defaults to "demo" if unset.
NEXT_PUBLIC_AGE_VERIFY_MODE=demo

# Public Yoti client SDK id (safe to expose in the browser):
NEXT_PUBLIC_YOTI_CLIENT_SDK_ID=

# Server-only Yoti credentials — NEVER expose these to the client:
YOTI_CLIENT_SDK_ID=
YOTI_API_KEY=


# --- Contact form email (Resend) ---
# The /contact form emails submissions to your inbox via Resend.
#
# 1. Create a free account at https://resend.com using hello@kamadesires.com
#    (signing up with that address lets you receive test emails without
#     verifying a domain first).
# 2. Create an API key (API Keys → Create) and paste it below. Keys start "re_".
# 3. In Vercel: Project → Settings → Environment Variables, add RESEND_API_KEY
#    with the same value, then redeploy.
#
# Server-only — NEVER expose this to the client:
RESEND_API_KEY=

# Optional. Defaults: CONTACT_TO=hello@kamadesires.com and
# CONTACT_FROM uses Resend's shared "onboarding@resend.dev" sender. After you
# verify kamadesires.com in Resend, set CONTACT_FROM to your own domain, e.g.
# "Kamatoys <contact@kamadesires.com>".
# CONTACT_TO=hello@kamadesires.com
# CONTACT_FROM=Kamatoys Contact <onboarding@resend.dev>
