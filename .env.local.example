# --- Customer accounts (Shopify Customer Account API) ---
# Accounts (login/signup) and the WhatsApp chat gate use Shopify's NEW
# (passwordless) customer accounts via the Customer Account API. No separate
# auth service is needed — customers get one login for shopping + chat.
#
# Setup in Shopify admin:
#  1. Install the free "Headless" sales channel
#     (Settings → Apps and sales channels → Shopify App Store → "Headless").
#  2. Open Headless → Customer Account API → and note the "Client ID".
#  3. In that same Customer Account API settings page, add your site URLs:
#       Callback URI(s):        https://kamatoys.vercel.app/api/auth/callback
#                               http://localhost:3000/api/auth/callback
#       JavaScript origin(s):   https://kamatoys.vercel.app
#                               http://localhost:3000
#       Logout URI:             https://kamatoys.vercel.app
#                               http://localhost:3000
#  4. Reuses SHOPIFY_STORE_DOMAIN (below) to discover the auth endpoints.
#
# The Client ID is a PUBLIC OAuth client id (safe to expose); the flow uses
# PKCE, so there is no client secret.
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=your_customer_account_api_client_id


# --- WhatsApp chat (masked number) ---
# Server-only. Because it has NO "NEXT_PUBLIC_" prefix, this number never
# reaches the browser — the /api/whatsapp/launch route injects it server-side
# after checking the customer is signed in.
# International format, digits only (no +, spaces or dashes). e.g. UK
# 07123 456789 -> "447123456789".
WHATSAPP_NUMBER=447000000000


# --- Shopify headless (Storefront API) ---
# Copy this file to ".env.local" (which is git-ignored) and fill in your values.
# In production, set the same variables in your Vercel project settings.
#
# 1. In Shopify admin: Settings → Apps and sales channels → Develop apps
#    → Create an app → Configure Storefront API scopes
#    (enable: read_products, read_product_listings; for cart/checkout later:
#     unauthenticated_read_product_listings, unauthenticated_write_checkouts).
# 2. Install the app, then copy the "Storefront API access token".
#
# Your store's *.myshopify.com domain (NOT the custom domain):
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# The Storefront API access token from your custom app:
SHOPIFY_STOREFRONT_TOKEN=your_storefront_api_token_here


# --- Age verification (18+) ---
# Mode: "yoti" (real Yoti flow), "demo" (simulated, for testing), or "off"
# (fail-closed: checkout blocked). Defaults to "demo" if unset.
NEXT_PUBLIC_AGE_VERIFY_MODE=demo

# Public Yoti client SDK id (safe to expose in the browser):
NEXT_PUBLIC_YOTI_CLIENT_SDK_ID=

# Server-only Yoti credentials — NEVER expose these to the client:
YOTI_CLIENT_SDK_ID=
YOTI_API_KEY=


# --- Contact form email (Zoho SMTP) ---
# The /contact form authenticates as a REAL Zoho mailbox and emails each
# submission to the kamadesires.com group inbox.
#
# IMPORTANT: SMTP_USER must be a real login mailbox (one that can generate an
# app password) — NOT a group/alias address. A group has no password, so SMTP
# auth against it fails with "535 Authentication Failed".
#
# 1. Log in as your real mailbox at mail.zoho.eu (e.g. jatinatri@zohomail.eu).
# 2. Settings → Security → App Passwords → Generate New Password ("kamatoys-site").
# 3. Set SMTP_USER to that mailbox and SMTP_PASS to the app password.
# 4. In Vercel: Settings → Environment Variables, add SMTP_USER and SMTP_PASS,
#    then redeploy.
#
# Server-only — NEVER expose SMTP_PASS to the client:
SMTP_USER=jatinatri@zohomail.eu
SMTP_PASS=

# Optional. Defaults: SMTP_HOST=smtp.zoho.eu (EU individual mailbox; use
# smtppro.zoho.eu for paid org custom-domain mailboxes), SMTP_PORT=465,
# CONTACT_TO=hello@kamadesires.com (the group that receives submissions).
# SMTP_HOST=smtp.zoho.eu
# SMTP_PORT=465
# CONTACT_TO=hello@kamadesires.com
